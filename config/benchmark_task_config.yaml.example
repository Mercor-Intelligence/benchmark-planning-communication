# Planning & Communication benchmark configuration
# All SweBenchExtConfig options are inherited.

# Context sections to exclude from agent prompts
# Options: problem_statement, requirements, interface
excluded_context: []

# Rubric paths within each task directory
planning_rubric_file: rubric/planning.json
execution_rubric_file: rubric/execution.json

# Reminder policy (modes: "off", "constant")
reminder_policy:
  readme_mode: "off"
  ask_question_mode: "off"
  artifact_mode: "off"

# Docker image template (for pre-built images from ECR)
# {task_id} is replaced with the task identifier at runtime
# image_uri_template: "YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/apex-swe-bench-ext:{task_id}"

# S3 task source path (for s3_bundle/s3_zip task sources)
# s3_task_source_path: "s3://YOUR_BUCKET/YOUR_PREFIX"
