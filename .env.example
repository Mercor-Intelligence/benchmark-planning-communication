# AWS — required for S3 task sources and ECR image pulls
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# LLM provider API keys — for plan grading / run_plan_grading.py (set the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Gemini: use GOOGLE_API_KEY (or GEMINI_API_KEY); can use backup key if needed
GOOGLE_API_KEY=
# Fireworks: FIREWORKS_AI_API_KEY or FIREWORKS_API_KEY (both work for Kimi K2, Qwen3-32b)
FIREWORKS_API_KEY=
# ByteDance/Volcengine ARK: BYTEDANCE_API_KEY or ARK_API_KEY
BYTEDANCE_API_KEY=

# Modal — required for remote sandbox execution
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
